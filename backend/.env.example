# Server
PORT=5000
NODE_ENV=development

# MongoDB - Leave empty to auto-start in-memory MongoDB (for development)
# For production, use MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cashli?retryWrites=true&w=majority
MONGODB_URI=

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Default admin credentials (used by seed)
ADMIN_EMAIL=admin@cashli.com
ADMIN_PASSWORD=Admin@123

# Optional: Stripe/PayPal (for production payouts)
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
