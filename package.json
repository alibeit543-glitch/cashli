{
  "name": "cashli-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Cashli - Get Paid To App (Monorepo)",
  "scripts": {
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm start",
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd ../mobile && npm install",
    "seed": "cd backend && npm run seed",
    "build": "cd frontend && npm run build"
  }
}
